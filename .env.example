ANGELONE_TOTP_SECRET=your_totp_secret
ANGELONE_API_KEY=your_api_key
ANGELONE_CLIENT_CODE=your_client_code
ANGELONE_PASSWORD=your_password

ENCRYPTION_KEY=your_base64_encryption_key

# Comma-separated list of origins allowed to call this API from a browser.
# Defaults to localhost:3000/3001 + https://tradeplatforms.duckdns.org — override if the frontend moves.
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001,https://tradeplatforms.duckdns.org

# Switch between local and cloud DB
# Local: jdbc:postgresql://localhost:5432/trading_platform
# Cloud: jdbc:postgresql://your-host:port/defaultdb?sslmode=require
DB_URL=jdbc:postgresql://localhost:5432/trading_platform
DB_USERNAME=postgres
DB_PASSWORD=your_password
